<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Contratos Daniel</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,600;9..144,700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --navy:#0a1628;--navy2:#0f1e38;--navy3:#162847;--navy4:#1d3460;
  --blue:#2563eb;--blue2:#3b82f6;--glow:rgba(37,99,235,.28);
  --gold:#f0b429;
  --danger:#ef4444;--danger-bg:rgba(239,68,68,.12);
  --warn:#f59e0b;--warn-bg:rgba(245,158,11,.12);
  --ok:#10b981;--ok-bg:rgba(16,185,129,.12);
  --text:#e2eaf8;--text2:#8fa3c8;
  --border:rgba(37,99,235,.18);--border2:rgba(37,99,235,.3);
  --surface:rgba(15,30,56,.8);--surface2:rgba(22,40,71,.9);
  --r:10px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--navy);
  color:var(--text);
  min-height:100vh;
  overflow-x:hidden;
  background-image:
    radial-gradient(ellipse 80% 50% at 50% -10%,rgba(37,99,235,.18) 0%,transparent 70%),
    linear-gradient(rgba(37,99,235,.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(37,99,235,.03) 1px,transparent 1px);
  background-size:100% 100%,44px 44px,44px 44px;
}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--navy)}
::-webkit-scrollbar-thumb{background:var(--navy4);border-radius:4px}
::-webkit-scrollbar-thumb:hover{background:var(--blue)}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes pulseDot{0%,100%{box-shadow:0 0 0 0 rgba(239,68,68,.4)}60%{box-shadow:0 0 0 6px rgba(239,68,68,0)}}
@keyframes slideDown{from{opacity:0;transform:translateY(-10px)}to{opacity:1;transform:translateY(0)}}
@keyframes scaleIn{from{opacity:0;transform:scale(.96) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}

/* HEADER */
header{
  position:sticky;top:0;z-index:100;
  background:rgba(9,18,35,.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);
  padding:0 32px;height:66px;
  display:flex;align-items:center;justify-content:space-between;gap:16px;
}
.brand{display:flex;align-items:center;gap:14px;flex-shrink:0}
.logo-wrap{
  width:40px;height:40px;border-radius:10px;
  background:linear-gradient(135deg,var(--blue) 0%,#1a45c8 100%);
  display:flex;align-items:center;justify-content:center;
  font-family:'Fraunces',serif;font-size:16px;font-weight:700;color:#fff;
  box-shadow:0 0 0 2px var(--glow),0 4px 16px rgba(37,99,235,.35);
  cursor:pointer;overflow:hidden;flex-shrink:0;
  transition:box-shadow .25s,transform .18s;
  position:relative;
}
.logo-wrap:hover{box-shadow:0 0 0 4px var(--glow),0 4px 20px rgba(37,99,235,.5);transform:scale(1.04)}
.logo-wrap img{width:100%;height:100%;object-fit:cover;position:absolute;inset:0;display:none}
.logo-letters{}
.brand-name{font-family:'Fraunces',serif;font-size:18px;font-weight:600;color:var(--text);letter-spacing:.01em}
.brand-tag{font-family:'DM Mono',monospace;font-size:10px;color:var(--blue2);letter-spacing:.14em;text-transform:uppercase;margin-top:1px}
.h-actions{display:flex;gap:9px;align-items:center}

/* BUTTONS */
.btn{
  font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;
  border:none;cursor:pointer;border-radius:8px;padding:9px 16px;
  display:inline-flex;align-items:center;gap:7px;
  transition:all .18s;white-space:nowrap;
}
.btn svg{width:14px;height:14px;flex-shrink:0}
.btn-primary{
  background:linear-gradient(135deg,var(--blue),#1a45c8);
  color:#fff;box-shadow:0 2px 14px rgba(37,99,235,.38);
}
.btn-primary:hover{background:linear-gradient(135deg,var(--blue2),var(--blue));box-shadow:0 4px 22px rgba(37,99,235,.55);transform:translateY(-1px)}
.btn-primary:active{transform:translateY(0)}
.btn-ghost{background:transparent;color:var(--text2);border:1px solid var(--border2)}
.btn-ghost:hover{color:var(--text);border-color:var(--blue2);background:var(--glow)}

/* TABS */
.tabs{
  background:rgba(9,18,35,.85);backdrop-filter:blur(14px);
  border-bottom:1px solid var(--border);
  padding:0 32px;display:flex;overflow-x:auto;
}
.tab{
  font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.08em;text-transform:uppercase;
  padding:15px 20px;border:none;background:none;cursor:pointer;
  color:var(--text2);border-bottom:2px solid transparent;
  display:flex;align-items:center;gap:8px;white-space:nowrap;
  transition:color .18s,border-color .18s;
}
.tab:hover{color:var(--text)}
.tab.active{color:var(--blue2);border-bottom-color:var(--blue2)}
.badge{
  font-family:'DM Sans',sans-serif;font-size:10px;font-weight:600;
  padding:2px 8px;border-radius:20px;min-width:20px;text-align:center;
  background:var(--navy4);color:var(--text2);transition:all .2s;
}
.badge.red{background:rgba(239,68,68,.2);color:var(--danger);animation:pulseDot 2.2s infinite}
.badge.amber{background:var(--warn-bg);color:var(--warn)}
.badge.blue{background:rgba(37,99,235,.2);color:var(--blue2)}

/* LAYOUT */
main{padding:28px 32px;max-width:1480px;margin:0 auto}
.tab-section{display:none}
.tab-section.active{display:block;animation:fadeUp .32s ease both}

/* KPI CARDS */
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:26px}
.kpi{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--r);
  padding:18px 20px;display:flex;flex-direction:column;gap:4px;
  transition:transform .18s,border-color .2s,box-shadow .2s;
  animation:fadeUp .4s ease both;
}
.kpi:hover{transform:translateY(-2px);border-color:var(--border2);box-shadow:0 6px 24px rgba(0,0,0,.25)}
.kpi.red{border-color:rgba(239,68,68,.25);background:rgba(239,68,68,.06)}
.kpi.amber{border-color:rgba(245,158,11,.25);background:rgba(245,158,11,.06)}
.kpi.green{border-color:rgba(16,185,129,.25);background:rgba(16,185,129,.06)}
.kpi.blue{border-color:var(--border2);background:var(--surface2)}
.kpi-lbl{font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--text2)}
.kpi-val{font-family:'Fraunces',serif;font-size:36px;font-weight:600;line-height:1.05}
.kpi.red .kpi-val{color:var(--danger)}
.kpi.amber .kpi-val{color:var(--warn)}
.kpi.green .kpi-val{color:var(--ok)}
.kpi.blue .kpi-val{color:var(--blue2)}
.kpi-desc{font-size:11.5px;color:var(--text2)}

/* TOOLBAR */
.toolbar{display:flex;gap:10px;align-items:center;margin-bottom:14px;flex-wrap:wrap}
.search-wrap{flex:1;min-width:200px;position:relative;display:flex;align-items:center}
.search-wrap svg{position:absolute;left:11px;width:14px;height:14px;color:var(--text2);pointer-events:none}
.search-input{
  width:100%;background:var(--surface);border:1px solid var(--border);border-radius:8px;
  padding:9px 13px 9px 34px;color:var(--text);
  font-family:'DM Sans',sans-serif;font-size:13px;outline:none;
  transition:border-color .18s,box-shadow .18s;
}
.search-input:focus{border-color:var(--blue);box-shadow:0 0 0 3px var(--glow)}
.search-input::placeholder{color:var(--text2)}
.sel{
  background:var(--surface);border:1px solid var(--border);border-radius:8px;
  padding:9px 13px;color:var(--text);
  font-family:'DM Mono',monospace;font-size:11px;
  outline:none;cursor:pointer;transition:border-color .18s;
}
.sel:focus{border-color:var(--blue)}

/* LEGEND */
.legend{display:flex;gap:18px;margin-bottom:12px;flex-wrap:wrap}
.legend-item{display:flex;align-items:center;gap:6px;font-size:11.5px;color:var(--text2)}
.ldot{width:8px;height:8px;border-radius:50%}

/* TABLE */
.table-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.table-scroll{overflow-x:auto}
table{width:100%;border-collapse:collapse;min-width:640px}
thead tr{background:rgba(15,30,56,.95);border-bottom:1px solid var(--border)}
th{
  font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.1em;text-transform:uppercase;
  color:var(--text2);padding:13px 16px;text-align:left;font-weight:500;
  white-space:nowrap;cursor:pointer;user-select:none;transition:color .15s;
}
th:hover{color:var(--text)}
.sort-arrow{opacity:.3;margin-left:3px;font-size:10px}
.th-active .sort-arrow{opacity:1;color:var(--blue2)}
tbody tr{border-bottom:1px solid var(--border);transition:background .1s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:rgba(22,40,71,.6)}
td{padding:13px 16px;font-size:13px;vertical-align:middle}
.td-name{font-weight:500}
.td-cnpj,.td-num{font-family:'DM Mono',monospace;font-size:11.5px}
.td-cnpj{color:var(--text2)}
.td-num{color:var(--blue2)}
.td-obs{font-size:12px;color:var(--text2);max-width:180px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}

/* STATUS PILLS */
.pill{
  display:inline-flex;align-items:center;gap:5px;
  font-family:'DM Mono',monospace;font-size:10.5px;font-weight:500;
  padding:3px 10px;border-radius:5px;white-space:nowrap;
}
.pdot{width:6px;height:6px;border-radius:50%;background:currentColor;flex-shrink:0}
.pill-red{background:var(--danger-bg);color:var(--danger);border:1px solid rgba(239,68,68,.2)}
.pill-amber{background:var(--warn-bg);color:var(--warn);border:1px solid rgba(245,158,11,.2)}
.pill-green{background:var(--ok-bg);color:var(--ok);border:1px solid rgba(16,185,129,.2)}
.pill-grey{background:rgba(255,255,255,.05);color:var(--text2);border:1px solid var(--border)}

/* DAYS */
.days{font-family:'DM Mono',monospace;font-size:12px;font-weight:500}
.days.red{color:var(--danger)}.days.amber{color:var(--warn)}.days.green{color:var(--ok)}.days.grey{color:var(--text2)}

/* ROW ACTIONS */
.acts{display:flex;gap:6px;justify-content:flex-end}
.ibtn{
  background:none;border:1px solid var(--border);border-radius:6px;
  color:var(--text2);cursor:pointer;padding:5px 9px;font-size:13px;line-height:1;
  transition:all .15s;
}
.ibtn:hover{color:var(--text);border-color:var(--border2);background:var(--navy3)}
.ibtn.del:hover{color:var(--danger);border-color:rgba(239,68,68,.35);background:var(--danger-bg)}

/* EMPTY */
.empty{text-align:center;padding:70px 20px;animation:fadeIn .35s ease}
.empty-ico{font-size:42px;opacity:.2;margin-bottom:14px}
.empty-title{font-family:'Fraunces',serif;font-size:19px;margin-bottom:6px}
.empty-sub{font-size:13px;color:var(--text2);line-height:1.6;max-width:300px;margin:0 auto}

/* OVERLAY / MODAL */
.overlay{
  position:fixed;inset:0;z-index:200;
  background:rgba(5,12,26,.82);backdrop-filter:blur(8px);
  display:flex;align-items:center;justify-content:center;padding:16px;
  opacity:0;pointer-events:none;transition:opacity .22s;
}
.overlay.open{opacity:1;pointer-events:all}
.modal{
  background:linear-gradient(160deg,var(--navy2) 0%,var(--navy3) 100%);
  border:1px solid var(--border2);border-radius:14px;
  width:100%;max-width:540px;
  box-shadow:0 24px 60px rgba(0,0,0,.65);
  transform:scale(.96) translateY(22px);opacity:0;
  transition:transform .28s cubic-bezier(.34,1.56,.64,1),opacity .22s;
  max-height:92vh;overflow-y:auto;
}
.overlay.open .modal{transform:scale(1) translateY(0);opacity:1}
.modal-head{padding:24px 26px 0;display:flex;align-items:flex-start;justify-content:space-between;gap:12px}
.modal-title{font-family:'Fraunces',serif;font-size:21px;font-weight:600;color:var(--text)}
.modal-sub{font-size:13px;color:var(--text2);margin-top:4px;line-height:1.5}
.mclose{background:none;border:none;color:var(--text2);cursor:pointer;font-size:19px;padding:2px;transition:color .15s}
.mclose:hover{color:var(--text)}
.modal-body{padding:22px 26px}
.modal-foot{padding:14px 26px 24px;display:flex;gap:10px;justify-content:flex-end;border-top:1px solid var(--border)}

/* FORM */
.fg{margin-bottom:14px}
.flabel{display:block;font-family:'DM Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--text2);margin-bottom:7px}
.finput{
  width:100%;background:rgba(9,18,35,.8);border:1px solid var(--border);border-radius:8px;
  padding:10px 13px;color:var(--text);
  font-family:'DM Sans',sans-serif;font-size:13px;outline:none;
  transition:border-color .18s,box-shadow .18s;
}
.finput:focus{border-color:var(--blue);box-shadow:0 0 0 3px var(--glow)}
.finput::placeholder{color:var(--text2)}
textarea.finput{resize:vertical;min-height:82px;line-height:1.55}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:12px}

/* UPLOAD */
.drop-zone{
  border:2px dashed var(--border2);border-radius:10px;padding:36px 20px;
  text-align:center;cursor:pointer;transition:all .2s;margin-bottom:14px;
}
.drop-zone:hover,.drop-zone.drag{border-color:var(--blue);background:var(--glow)}
.dico{font-size:34px;margin-bottom:10px;opacity:.55}
.dtxt{font-size:14px;font-weight:500;margin-bottom:4px}
.dhint{font-size:12px;color:var(--text2)}
.fmt-box{
  background:rgba(9,18,35,.7);border:1px solid var(--border);border-radius:8px;
  padding:14px 16px;font-family:'DM Mono',monospace;font-size:11px;color:var(--text2);line-height:1.9;
}
.fmt-box strong{color:var(--gold)}

/* TOAST */
.toast{
  position:fixed;bottom:22px;right:22px;z-index:400;
  background:var(--navy2);border:1px solid var(--border2);border-radius:10px;
  padding:13px 18px;font-size:13px;color:var(--text);
  box-shadow:0 10px 36px rgba(0,0,0,.55);
  display:flex;align-items:center;gap:10px;max-width:320px;
  transform:translateY(80px) scale(.96);opacity:0;
  transition:all .28s cubic-bezier(.34,1.56,.64,1);pointer-events:none;
}
.toast.show{transform:translateY(0) scale(1);opacity:1}
.toast.ok{border-color:rgba(16,185,129,.4)}
.toast.err{border-color:rgba(239,68,68,.4)}
.t-ico{font-size:17px}

/* MOBILE FAB */
.fab{
  display:none;position:fixed;bottom:20px;right:20px;z-index:150;
  width:52px;height:52px;border-radius:50%;border:none;
  background:linear-gradient(135deg,var(--blue),#1a45c8);
  color:#fff;font-size:26px;cursor:pointer;
  box-shadow:0 4px 22px rgba(37,99,235,.5);
  align-items:center;justify-content:center;transition:transform .18s;
}
.fab:active{transform:scale(.9)}

/* RESPONSIVE */
@media(max-width:760px){
  header{padding:0 16px;height:58px}
  .brand-tag,.h-actions .btn-ghost:not(.show-mob){display:none}
  .tabs{padding:0 16px}
  .tab{padding:12px 14px;font-size:10px}
  main{padding:16px}
  .kpis{grid-template-columns:1fr 1fr;gap:10px}
  .kpi{padding:14px 14px}
  .kpi-val{font-size:28px}
  .frow{grid-template-columns:1fr}
  .fab{display:flex}
  .td-obs{display:none}
  td,th{padding:10px 12px}
}
@media(max-width:420px){
  .kpis{grid-template-columns:1fr 1fr}
  .kpi-lbl{font-size:8.5px}
}
@media print{
  header,.tabs,.toolbar,.acts,.fab{display:none!important}
  body{background:#fff;color:#000}
  .tab-section{display:block!important}
  .kpi,.table-card{border:1px solid #ccc}
  td,th{color:#000;border-bottom:1px solid #eee}
}
</style>
</head>
<body>

<header>
  <div class="brand">
    <div class="logo-wrap" id="logo-wrap" title="Clique para trocar o logo" onclick="document.getElementById('logo-file').click()">
      <img id="logo-img" src="" alt="logo"/>
      <span id="logo-letters">CD</span>
    </div>
    <input type="file" id="logo-file" accept="image/*" style="display:none" onchange="swapLogo(event)"/>
    <div>
      <div class="brand-name">Contratos Daniel</div>
      <div class="brand-tag">Gestão de Contratos</div>
    </div>
  </div>
  <div class="h-actions">
    <button class="btn btn-ghost show-mob" onclick="openImport()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      Importar
    </button>
    <button class="btn btn-ghost" onclick="doExport()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Exportar
    </button>
    <button class="btn btn-primary" onclick="openAdd()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Novo Contrato
    </button>
  </div>
</header>

<div class="tabs">
  <button class="tab active" id="tab-venc" onclick="switchTab('venc')">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    Vencimento
    <span class="badge" id="bv">0</span>
  </button>
  <button class="tab" id="tab-reaj" onclick="switchTab('reaj')">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
    Aniversário / Reajuste
    <span class="badge" id="br">0</span>
  </button>
</div>

<main>

  <!-- VENCIMENTO -->
  <div class="tab-section active" id="sec-venc">
    <div class="kpis" id="kpis-venc"></div>
    <div class="legend">
      <div class="legend-item"><div class="ldot" style="background:var(--danger)"></div>Vencido ou ≤ 30 dias</div>
      <div class="legend-item"><div class="ldot" style="background:var(--warn)"></div>31 – 60 dias</div>
      <div class="legend-item"><div class="ldot" style="background:var(--ok)"></div>Mais de 60 dias</div>
    </div>
    <div class="toolbar">
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="search-input" id="sv" placeholder="Buscar cliente, CNPJ ou contrato…" oninput="renderVenc()"/>
      </div>
      <select class="sel" id="fv" onchange="renderVenc()">
        <option value="">Todos</option>
        <option value="danger">Crítico (≤ 30 dias)</option>
        <option value="warn">Atenção (31–60 dias)</option>
        <option value="ok">Em dia (&gt; 60 dias)</option>
        <option value="expired">Vencidos</option>
      </select>
    </div>
    <div class="table-card">
      <div class="table-scroll">
        <table id="tbl-venc">
          <thead><tr>
            <th id="th-vc" onclick="doSort('client')">Cliente <span class="sort-arrow">↕</span></th>
            <th>CNPJ</th><th>Contrato</th>
            <th id="th-vv" onclick="doSort('venc')" class="th-active">Vencimento <span class="sort-arrow">↕</span></th>
            <th>Status</th><th>Dias restantes</th><th>Observações</th><th></th>
          </tr></thead>
          <tbody id="body-venc"></tbody>
        </table>
      </div>
      <div id="empty-venc" class="empty" style="display:none">
        <div class="empty-ico">📋</div>
        <div class="empty-title">Nenhum contrato encontrado</div>
        <div class="empty-sub">Importe uma planilha ou adicione contratos manualmente.</div>
      </div>
    </div>
  </div>

  <!-- REAJUSTE -->
  <div class="tab-section" id="sec-reaj">
    <div class="kpis" id="kpis-reaj"></div>
    <div class="legend">
      <div class="legend-item"><div class="ldot" style="background:var(--danger)"></div>Reajuste pendente (aniversário passou)</div>
      <div class="legend-item"><div class="ldot" style="background:var(--warn)"></div>Aniversário em até 30 dias</div>
