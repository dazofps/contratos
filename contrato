<!-- TOAST -->
<div class="toast" id="toast"><span class="t-ico" id="t-ico"></span><span id="t-msg"></span></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script>
// ── STATE ──────────────────────────────────────────────────────
let db = (()=>{ try{ return JSON.parse(localStorage.getItem('cd3')||'[]'); } catch{ return []; } })();
let editId = null, sortKey = 'venc', sortDir = 1;
const TODAY = (()=>{ const d=new Date(); d.setHours(0,0,0,0); return d; })();

function saveDB(){ localStorage.setItem('cd3', JSON.stringify(db)); }
function uid(){ return Date.now().toString(36)+Math.random().toString(36).slice(2,6); }
function esc(s){ return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ── DATE UTILS ────────────────────────────────────────────────
function parseDate(v){
  if(!v) return null;
  if(v instanceof Date) return isNaN(v.getTime())?null:v;
  if(typeof v==='number'){ const d=new Date(Math.round((v-25569)*86400000)); return isNaN(d.getTime())?null:d; }
  const s=String(v).trim();
  if(/^\d{1,2}\/\d{1,2}\/\d{4}$/.test(s)){ const[dd,mm,yy]=s.split('/'); return new Date(+yy,+mm-1,+dd); }
  if(/^\d{4}-\d{2}-\d{2}/.test(s)){ const d=new Date(s+'T00:00:00'); return isNaN(d.getTime())?null:d; }
  return null;
}
function fmtD(d){ return d ? d.toLocaleDateString('pt-BR') : '—'; }
function diff(d){ return d ? Math.round((d.getTime()-TODAY.getTime())/86400000) : null; }
function nextAniv(d){
  if(!d) return null;
  const n=new Date(d); n.setFullYear(TODAY.getFullYear());
  if(n<TODAY) n.setFullYear(TODAY.getFullYear()+1);
  return n;
}
function toInput(d){ return d ? d.toISOString().slice(0,10) : ''; }

// ── STATUS ────────────────────────────────────────────────────
function stVenc(days){
  if(days===null) return{p:'pill-grey',l:'Sem data',lv:'none',d:'grey'};
  if(days<0)      return{p:'pill-red',l:'Vencido',lv:'danger',d:'red'};
  if(days<=30)    return{p:'pill-red',l:'Crítico',lv:'danger',d:'red'};
  if(days<=60)    return{p:'pill-amber',l:'Atenção',lv:'warn',d:'amber'};
  return{p:'pill-green',l:'Em dia',lv:'ok',d:'green'};
}
function stReaj(days){
  if(days===null)  return{p:'pill-grey',l:'Sem data',lv:'none'};
  if(days>330)     return{p:'pill-red',l:'Reajuste pendente',lv:'danger'};
  if(days<=30)     return{p:'pill-amber',l:'Aniversário próximo',lv:'warn'};
  return{p:'pill-green',l:'Em dia',lv:'ok'};
}

// ── TABS ──────────────────────────────────────────────────────
function switchTab(t){
  document.querySelectorAll('.tab').forEach(e=>e.classList.remove('active'));
  document.querySelectorAll('.tab-section').forEach(e=>e.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  const s=document.getElementById('sec-'+t);
  s.classList.add('active');
  void s.offsetWidth; // reflow to re-trigger animation
}

// ── SORT ──────────────────────────────────────────────────────
function doSort(k){
  sortKey===k ? sortDir*=-1 : (sortKey=k, sortDir=1);
  // update header highlights
  document.querySelectorAll('th[id]').forEach(th=>th.classList.remove('th-active'));
  const map={client:['th-vc','th-rc'],venc:['th-vv'],aniv:['th-ra']};
  (map[k]||[]).forEach(id=>{ const el=document.getElementById(id); if(el) el.classList.add('th-active'); });
  renderAll();
}

// ── RENDER VENCIMENTO ─────────────────────────────────────────
function renderVenc(){
  const q=(document.getElementById('sv').value||'').toLowerCase();
  const f=document.getElementById('fv').value;

  let rows=[...db].filter(c=>{
    if(q && ![c.client,c.cnpj||'',c.contrato||''].some(x=>x.toLowerCase().includes(q))) return false;
    const d=diff(c.vencDate), st=stVenc(d);
    if(f==='danger') return st.lv==='danger' && d>=0;
    if(f==='warn')   return st.lv==='warn';
    if(f==='ok')     return st.lv==='ok';
    if(f==='expired') return d!==null && d<0;
    return true;
  });
  rows.sort((a,b)=>{
    if(sortKey==='client') return sortDir*a.client.localeCompare(b.client,'pt-BR');
    const da=a.vencDate?a.vencDate.getTime():Infinity, db2=b.vencDate?b.vencDate.getTime():Infinity;
    return sortDir*(da-db2);
  });

  const tbody=document.getElementById('body-venc');
  tbody.innerHTML='';
  const empty=document.getElementById('empty-venc');
  const tbl=document.getElementById('tbl-venc');
  if(!rows.length){ tbl.style.display='none'; empty.style.display=''; }
  else{ tbl.style.display=''; empty.style.display='none'; }

  rows.forEach((c,i)=>{
    const days=diff(c.vencDate), st=stVenc(days);
    const dChip = days===null ? '<span class="days grey">—</span>'
      : `<span class="days ${st.d}">${days<0?Math.abs(days)+'d atrás':days===0?'Hoje!':days+'d'}</span>`;
    const tr=document.createElement('tr');
    tr.style.animationDelay=(i*25)+'ms';
    tr.classList.add(); // no class needed, CSS handles tbody tr
    tr.innerHTML=`
      <td class="td-name">${esc(c.client)}</td>
      <td class="td-cnpj">${esc(c.cnpj||'—')}</td>
      <td class="td-num">${esc(c.contrato||'—')}</td>
      <td>${fmtD(c.vencDate)}</td>
      <td><span class="pill ${st.p}"><span class="pdot"></span>${st.l}</span></td>
      <td>${dChip}</td>
      <td class="td-obs" title="${esc(c.obs||'')}">${esc(c.obs||'—')}</td>
      <td><div class="acts">
        <button class="ibtn" onclick="openEdit('${c.id}')" title="Editar">✏️</button>
        <button class="ibtn del" onclick="delC('${c.id}')" title="Excluir">✕</button>
      </div></td>`;
    tbody.appendChild(tr);
  });

  // KPIs
  let exp=0,crit=0,warn=0,ok=0;
  db.forEach(c=>{ const d=diff(c.vencDate); if(d===null) return;
    if(d<0)exp++; else if(d<=30)crit++; else if(d<=60)warn++; else ok++; });
  document.getElementById('kpis-venc').innerHTML=kpiHTML([
    {cls:'red',lbl:'Vencidos',val:exp,desc:'contratos',delay:0},
    {cls:'red',lbl:'Crítico ≤30d',val:crit,desc:'contratos',delay:60},
    {cls:'amber',lbl:'Atenção 31–60d',val:warn,desc:'contratos',delay:120},
    {cls:'green',lbl:'Em dia',val:ok,desc:'contratos',delay:180},
    {cls:'blue',lbl:'Total geral',val:db.length,desc:'cadastrados',delay:240},
  ]);
  const alert=exp+crit;
  const bv=document.getElementById('bv');
  bv.textContent=alert||db.length; bv.className='badge '+(alert?'red':db.length?'blue':'');
}

// ── RENDER REAJUSTE ───────────────────────────────────────────
function renderReaj(){
  const q=(document.getElementById('sr').value||'').toLowerCase();
  const f=document.getElementById('fr').value;

  let rows=[...db].filter(c=>{
    if(q && ![c.client,c.cnpj||'',c.contrato||''].some(x=>x.toLowerCase().includes(q))) return false;
    const nx=nextAniv(c.anivDate), d=diff(nx), st=stReaj(d);
    if(f==='danger') return st.lv==='danger';
    if(f==='warn')   return st.lv==='warn';
    if(f==='ok')     return st.lv==='ok';
    return true;
  });
  rows.sort((a,b)=>{
    if(sortKey==='client') return sortDir*a.client.localeCompare(b.client,'pt-BR');
    const na=nextAniv(a.anivDate), nb=nextAniv(b.anivDate);
    return sortDir*((na?na.getTime():Infinity)-(nb?nb.getTime():Infinity));
  });

  const tbody=document.getElementById('body-reaj');
  tbody.innerHTML='';
  const empty=document.getElementById('empty-reaj');
  const tbl=document.getElementById('tbl-reaj');
  if(!rows.length){ tbl.style.display='none'; empty.style.display=''; }
  else{ tbl.style.display=''; empty.style.display='none'; }

  rows.forEach((c,i)=>{
    const nx=nextAniv(c.anivDate), d=diff(nx), st=stReaj(d);
    const tr=document.createElement('tr');
    tr.innerHTML=`
      <td class="td-name">${esc(c.client)}</td>
      <td class="td-cnpj">${esc(c.cnpj||'—')}</td>
      <td class="td-num">${esc(c.contrato||'—')}</td>
      <td>${fmtD(c.anivDate)}</td>
      <td>${fmtD(nx)}</td>
      <td><span class="pill ${st.p}"><span class="pdot"></span>${st.l}</span></td>
      <td class="td-obs" title="${esc(c.obs||'')}">${esc(c.obs||'—')}</td>
      <td><div class="acts">
        <button class="ibtn" onclick="openEdit('${c.id}')" title="Editar">✏️</button>
        <button class="ibtn del" onclick="delC('${c.id}')" title="Excluir">✕</button>
      </div></td>`;
    tbody.appendChild(tr);
  });

  let pend=0,near=0,ok=0;
  db.forEach(c=>{ const d=diff(nextAniv(c.anivDate)); const st=stReaj(d);
    if(st.lv==='danger')pend++; else if(st.lv==='warn')near++; else if(st.lv==='ok')ok++; });
  document.getElementById('kpis-reaj').innerHTML=kpiHTML([
    {cls:'red',lbl:'Reajuste pendente',val:pend,desc:'contratos',delay:0},
    {cls:'amber',lbl:'Aniversário ≤30d',val:near,desc:'contratos',delay:60},
    {cls:'green',lbl:'Em dia',val:ok,desc:'contratos',delay:120},
    {cls:'blue',lbl:'Total geral',val:db.length,desc:'cadastrados',delay:180},
  ]);
  const alert=pend+near;
  const brEl=document.getElementById('br');
  brEl.textContent=alert||db.length; brEl.className='badge '+(pend?'red':near?'amber':db.length?'blue':'');
}

function kpiHTML(items){
  return items.map(o=>`
    <div class="kpi ${o.cls}" style="animation-delay:${o.delay}ms">
      <div class="kpi-lbl">${o.lbl}</div>
      <div class="kpi-val">${o.val}</div>
      <div class="kpi-desc">${o.desc}</div>
    </div>`).join('');
}

function renderAll(){ renderVenc(); renderReaj(); }

// ── OVERLAY ───────────────────────────────────────────────────
function openOv(id){ document.getElementById(id).classList.add('open'); }
function closeOv(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(o=>{
  o.addEventListener('click',e=>{ if(e.target===o) o.classList.remove('open'); });
});
document.addEventListener('keydown',e=>{ if(e.key==='Escape') document.querySelectorAll('.overlay.open').forEach(o=>o.classList.remove('open')); });

// ── ADD / EDIT ────────────────────────────────────────────────
function openAdd(){
  editId=null;
  document.getElementById('add-title').textContent='Novo Contrato';
  ['fc','fcnpj','fnum','fobs'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('faniv').value='';
  document.getElementById('fvenc').value='';
  openOv('ov-add');
  setTimeout(()=>document.getElementById('fc').focus(),220);
}
function openEdit(id){
  const c=db.find(x=>x.id===id); if(!c) return;
  editId=id;
  document.getElementById('add-title').textContent='Editar Contrato';
  document.getElementById('fc').value=c.client;
  document.getElementById('fcnpj').value=c.cnpj||'';
  document.getElementById('fnum').value=c.contrato||'';
  document.getElementById('faniv').value=toInput(c.anivDate);
  document.getElementById('fvenc').value=toInput(c.vencDate);
  document.getElementById('fobs').value=c.obs||'';
  openOv('ov-add');
}
function saveContract(){
  const client=document.getElementById('fc').value.trim();
  if(!client){ showToast('Informe o nome do cliente.','err'); return; }
  const obj={
    client,
    cnpj:document.getElementById('fcnpj').value.trim(),
    contrato:document.getElementById('fnum').value.trim(),
    anivDate:parseDate(document.getElementById('faniv').value),
    vencDate:parseDate(document.getElementById('fvenc').value),
    obs:document.getElementById('fobs').value.trim(),
  };
  if(editId){ const i=db.findIndex(x=>x.id===editId); if(i!==-1) db[i]={...db[i],...obj}; }
  else db.push({id:uid(),...obj});
  saveDB(); closeOv('ov-add'); renderAll();
  showToast(editId?'Contrato atualizado ✓':'Contrato adicionado ✓','ok');
}
function delC(id){
  if(!confirm('Excluir este contrato?')) return;
  db=db.filter(c=>c.id!==id); saveDB(); renderAll();
  showToast('Contrato excluído.','ok');
}

// ── IMPORT ────────────────────────────────────────────────────
function openImport(){ openOv('ov-imp'); }
function onDrop(e){ e.preventDefault(); document.getElementById('dz').classList.remove('drag'); const f=e.dataTransfer.files[0]; if(f) procFile(f); }
function onFSel(e){ const f=e.target.files[0]; if(f) procFile(f); e.target.value=''; }

const COLS={
  client:['cliente','client','nome','razão social','razao social'],
  cnpj:['cnpj','cpf/cnpj','cpf'],
  contrato:['contrato','nº contrato','numero contrato','contract','num contrato'],
  aniv:['aniv. reajuste','aniversario','aniversário','aniv reajuste','reajuste','aniv.'],
  venc:['vencimento','venc','expiry','data vencimento','data de vencimento'],
  obs:['obs','observacao','observação','observações','observacoes','notas','notes'],
};
function findCol(row,key){
  const aliases=COLS[key], keys=Object.keys(row);
  for(const a of aliases){ const k=keys.find(k=>k.toLowerCase().trim().includes(a)); if(k) return row[k]; }
  return '';
}
function procFile(file){
  const ext=file.name.split('.').pop().toLowerCase();
  const r=new FileReader();
  r.onload=e=>{
    try{
      let rows;
      if(ext==='csv') rows=parseCSV(e.target.result);
      else{ const wb=XLSX.read(new Uint8Array(e.target.result),{type:'array'}); rows=XLSX.utils.sheet_to_json(wb.Sheets[wb.SheetNames[0]],{defval:''}); }
      importRows(rows);
    } catch(err){ showToast('Erro: '+err.message,'err'); }
  };
  if(ext==='csv') r.readAsText(file,'UTF-8'); else r.readAsArrayBuffer(file);
}
function parseCSV(text){
  const lines=text.split(/\r?\n/).filter(l=>l.trim());
  const sep=lines[0].includes(';')?';':',';
  const headers=lines[0].split(sep).map(h=>h.trim().toLowerCase());
  return lines.slice(1).map(line=>{ const vals=line.split(sep); const o={}; headers.forEach((h,i)=>o[h]=(vals[i]||'').trim()); return o; });
}
function importRows(rows){
  let added=0;
  rows.forEach(row=>{
    const client=String(findCol(row,'client')).trim(); if(!client) return;
    const contrato=String(findCol(row,'contrato')).trim();
    if(db.find(c=>c.client===client&&c.contrato===contrato)) return;
    db.push({ id:uid(), client, cnpj:String(findCol(row,'cnpj')).trim(), contrato,
      anivDate:parseDate(findCol(row,'aniv')), vencDate:parseDate(findCol(row,'venc')),
      obs:String(findCol(row,'obs')).trim() });
    added++;
  });
  saveDB(); closeOv('ov-imp'); renderAll();
  showToast(`${added} contrato(s) importado(s)!`,'ok');
}

// ── EXPORT ────────────────────────────────────────────────────
function doExport(){
  if(!db.length){ showToast('Nenhum contrato para exportar.','err'); return; }
  const data=db.map(c=>({
    'Cliente':c.client, 'CNPJ':c.cnpj||'', 'Contrato':c.contrato||'',
    'Aniv. Reajuste':fmtD(c.anivDate), 'Vencimento':fmtD(c.vencDate),
    'Status Vencimento':stVenc(diff(c.vencDate)).l,
    'Status Reajuste':stReaj(diff(nextAniv(c.anivDate))).l,
    'Observações':c.obs||'',
  }));
  const ws=XLSX.utils.json_to_sheet(data);
  ws['!cols']=[{wch:32},{wch:20},{wch:16},{wch:18},{wch:16},{wch:22},{wch:22},{wch:40}];
  const wb=XLSX.utils.book_new(); XLSX.utils.book_append_sheet(wb,'Contratos',ws);
  const date=new Date().toLocaleDateString('pt-BR').replace(/\//g,'-');
  XLSX.writeFile(wb,`contratos-daniel-${date}.xlsx`);
  showToast('Planilha exportada com sucesso!','ok');
}

// ── LOGO ──────────────────────────────────────────────────────
function swapLogo(e){
  const file=e.target.files[0]; if(!file) return;
  const r=new FileReader();
  r.onload=ev=>{
    const img=document.getElementById('logo-img');
    img.src=ev.target.result; img.style.display='block';
    document.getElementById('logo-letters').style.display='none';
    localStorage.setItem('cd3_logo',ev.target.result);
  };
  r.readAsDataURL(file);
}
(function initLogo(){
  const saved=localStorage.getItem('cd3_logo');
  if(saved){
    const img=document.getElementById('logo-img');
    img.src=saved; img.style.display='block';
    document.getElementById('logo-letters').style.display='none';
  }
})();

// ── TOAST ─────────────────────────────────────────────────────
let toastT;
function showToast(msg,type='ok'){
  const el=document.getElementById('toast');
  document.getElementById('t-ico').textContent=type==='ok'?'✅':'⚠️';
  document.getElementById('t-msg').textContent=msg;
  el.className='toast show '+(type==='ok'?'ok':'err');
  clearTimeout(toastT);
  toastT=setTimeout(()=>{ el.className='toast'; },3500);
}

// ── INIT ──────────────────────────────────────────────────────
renderAll();
</script>
</body>
